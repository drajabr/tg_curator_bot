BOT_TOKEN=123456789:YOUR_BOT_TOKEN

# Optional: container image used by docker-compose.yml
# IMAGE_NAME=ghcr.io/<owner>/<repo>:latest

# Optional fallback values for user client startup only.
# If omitted, owner can provide API ID/API Hash later via bot DM setup.
# BOT_API_ID=12345678
# BOT_API_HASH=0123456789abcdef0123456789abcdef
# API_ID=12345678
# API_HASH=0123456789abcdef0123456789abcdef

# Optional: container memory guardrails (docker-compose)
# CONTAINER_MEMORY_LIMIT=512m
# CONTAINER_MEMORY_SWAP_LIMIT=512m

# Optional: runtime memory housekeeping limits
# GLOBAL_DEDUPE_MAX_ENTRIES=3000
# CHAT_USERNAME_CACHE_MAX=2048
# BULK_IMPORT_SESSION_MAX=128
# BULK_IMPORT_SESSION_TTL_SECONDS=1800
# HOUSEKEEPING_INTERVAL_SECONDS=60